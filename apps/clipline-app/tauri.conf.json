{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Clipline",
  "version": "0.1.0",
  "identifier": "io.clipline.app",
  "build": {
    "frontendDist": "ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Clipline",
        "width": 1200,
        "height": 760,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**/Videos/Clipline/*.mp4",
          "**/Videos/Clipline/**/*.mp4"
        ]
      }
    }
  }
}
