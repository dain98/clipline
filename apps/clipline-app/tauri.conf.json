{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Clipline",
  "version": "0.1.12",
  "identifier": "io.clipline.app",
  "build": {
    "frontendDist": "ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Clipline",
        "width": 1200,
        "height": 760,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "decorations": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**/Videos/Clipline/*.mp4",
          "**/Videos/Clipline/**/*.mp4"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "publisher": "Clipline",
    "shortDescription": "Lightweight, ad-free game recorder with automatic event markers",
    "longDescription": "Clipline is a lightweight, ad-free, open-source game recorder for Windows — anti-cheat-safe capture, a ShadowPlay-style replay buffer, and automatic in-game event markers (League of Legends), with a built-in review/trim player.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "minimumWebview2Version": "120.0.2210.55",
      "webviewInstallMode": {
        "type": "offlineInstaller"
      },
      "nsis": {
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDg5RTA1MDk3MjY0QkU2RTYKUldUbTVrc21sMURnaVhoZVI0OGswbUM1dWU5bVFzbmFLMFBhM1M4Rzh2aXJQN2FyNkhJT0x1bloK",
      "endpoints": [
        "https://github.com/dain98/clipline/releases/download/nightly/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
